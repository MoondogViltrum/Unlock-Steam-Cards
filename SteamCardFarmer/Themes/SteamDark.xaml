<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  COLORS                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Color x:Key="SteamBg">#1B2838</Color>
    <Color x:Key="SteamPanel">#2A3F5F</Color>
    <Color x:Key="SteamCard">#16202D</Color>
    <Color x:Key="SteamBorder">#3D5A80</Color>
    <Color x:Key="SteamBlue">#1A9FFF</Color>
    <Color x:Key="SteamBlueHover">#4DB3FF</Color>
    <Color x:Key="SteamGreen">#A4D007</Color>
    <Color x:Key="SteamGreenDark">#6D8A00</Color>
    <Color x:Key="SteamText">#C6D4DF</Color>
    <Color x:Key="SteamTextDim">#8FA8C0</Color>
    <Color x:Key="SteamTextBright">#FFFFFF</Color>
    <Color x:Key="SteamRed">#FF4444</Color>
    <Color x:Key="SteamOrange">#FF8C00</Color>
    <Color x:Key="SteamAccent">#66C0F4</Color>
    <Color x:Key="SteamSurface">#213247</Color>
    <Color x:Key="SteamInputBg">#141D26</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource SteamBg}"/>
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource SteamPanel}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SteamCard}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource SteamBorder}"/>
    <SolidColorBrush x:Key="BlueBrush" Color="{StaticResource SteamBlue}"/>
    <SolidColorBrush x:Key="BlueHoverBrush" Color="{StaticResource SteamBlueHover}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource SteamGreen}"/>
    <SolidColorBrush x:Key="GreenDarkBrush" Color="{StaticResource SteamGreenDark}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource SteamText}"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource SteamTextDim}"/>
    <SolidColorBrush x:Key="TextBrightBrush" Color="{StaticResource SteamTextBright}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource SteamRed}"/>
    <SolidColorBrush x:Key="OrangeBrush" Color="{StaticResource SteamOrange}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource SteamAccent}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SteamSurface}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource SteamInputBg}"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  BUTTON                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="SteamButton" TargetType="Button">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2A5080" Offset="0"/>
                    <GradientStop Color="#1A3A60" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#3A6090" Offset="0"/>
                                        <GradientStop Color="#2A4A70" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#1A3050" Offset="0"/>
                                        <GradientStop Color="#0A2040" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SteamButtonGreen" TargetType="Button" BasedOn="{StaticResource SteamButton}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#5A8A00" Offset="0"/>
                    <GradientStop Color="#3D6000" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource GreenDarkBrush}"/>
    </Style>

    <Style x:Key="SteamButtonRed" TargetType="Button" BasedOn="{StaticResource SteamButton}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#8A2020" Offset="0"/>
                    <GradientStop Color="#601010" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
        <Setter Property="BorderBrush" Value="#8A2020"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  TEXTBOX                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="SteamTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource BlueBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  CHECKBOX                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="SteamCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  LISTBOX / LISTBOXITEM                                          -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="SteamListBox" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style x:Key="BadgeListItem" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  SCROLLBAR                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0" Height="0"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#3D5A80" CornerRadius="3"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" Height="0"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  SEPARATOR                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="0,6"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  PROGRESS BAR                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="SteamProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="4"/>
        <Setter Property="Background" Value="#0D1923"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                        <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                CornerRadius="2" HorizontalAlignment="Left"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  LABEL STYLES                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="StatLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style x:Key="StatValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

</ResourceDictionary>
