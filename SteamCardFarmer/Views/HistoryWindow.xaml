<Window x:Class="SteamCardFarmer.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historique" Width="420" Height="500"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Cursor="SizeAll">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0D1B2A" Offset="0"/>
                        <GradientStop Color="#1B2838" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0">
                    <TextBlock Text="📋  HISTORIQUE DES CARTES" Foreground="{StaticResource AccentBrush}"
                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="✕" Style="{StaticResource SteamButtonRed}"
                            HorizontalAlignment="Right" Padding="8,2" FontSize="13"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Liste -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8">
                <ItemsControl x:Name="HistoryList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Margin="4,3" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Summary}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding DateText}"
                                                   Foreground="{StaticResource TextDimBrush}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CardsDropped, StringFormat='+{0}'}"
                                               Foreground="{StaticResource GreenBrush}"
                                               FontSize="16" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="16,10">
                <Button Content="🗑  Effacer l'historique" Style="{StaticResource SteamButtonRed}"
                        Click="Clear_Click" HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </Border>
</Window>
