<Window x:Class="SteamCardFarmer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SteamCardFarmer.ViewModels"
        Title="Unlock Steam Cards"
        Width="960" Height="680"
        MinWidth="800" MinHeight="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- Root border (rounded window) -->
    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="32"/>   <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!--  TITLE BAR                                               -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Cursor="SizeAll">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0D1B2A" Offset="0"/>
                        <GradientStop Color="#1B2838" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo + Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Resources/icon.ico" Width="28" Height="28"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="UNLOCK STEAM CARDS" Foreground="{StaticResource AccentBrush}"
                                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text=" v1.0" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11" VerticalAlignment="Center" Margin="4,2,0,0"/>
                    </StackPanel>

                    <!-- User info -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVis}}">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource GreenBrush}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding UserName}" Foreground="{StaticResource TextBrush}" FontSize="13"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="⚙" Style="{StaticResource SteamButton}" Padding="10,2"
                                Click="Settings_Click" FontSize="14" ToolTip="Paramètres" Margin="0,0,4,0"/>
                        <Button Content="─" Style="{StaticResource SteamButton}" Padding="10,2"
                                Click="Minimize_Click" FontSize="14" ToolTip="Réduire" Margin="0,0,4,0"/>
                        <Button Content="✕" Style="{StaticResource SteamButtonRed}" Padding="10,2"
                                Click="Close_Click" FontSize="14" ToolTip="Fermer"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!--  MAIN CONTENT                                            -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT SIDEBAR ──────────────────────────────── -->
                <Border Grid.Column="0" Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>

                            <!-- LOGIN SECTION -->
                            <TextBlock Text="{Binding Loc.Auth}" Style="{StaticResource SectionHeader}"/>

                            <StackPanel Visibility="{Binding IsNotAuthenticated, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="steamLoginSecure" Foreground="{StaticResource TextDimBrush}"
                                           FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource SteamTextBox}"
                                         Text="{Binding SteamLoginSecure, UpdateSourceTrigger=PropertyChanged}"
                                         Height="60" TextWrapping="Wrap" AcceptsReturn="False"
                                         ToolTip="Cookie steamLoginSecure depuis les DevTools Steam"/>
                                <TextBlock Text="sessionid" Foreground="{StaticResource TextDimBrush}"
                                           FontSize="11" Margin="0,8,0,4"/>
                                <TextBox Style="{StaticResource SteamTextBox}"
                                         Text="{Binding SessionId, UpdateSourceTrigger=PropertyChanged}"/>

                                <Button Content="{Binding Loc.Connect}"
                                        Style="{StaticResource SteamButton}"
                                        Margin="0,12,0,0"
                                        Click="Login_Click"
                                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"/>

                                <Border Background="#0D1923" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,12,0,0">
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextDimBrush}">
                                        <Run Text="Comment obtenir les cookies ?"/>&#10;
                                        <Run Text="1. Ouvre Steam dans Chrome"/>&#10;
                                        <Run Text="2. F12 → Application → Cookies"/>&#10;
                                        <Run Text="3. steamcommunity.com"/>&#10;
                                        <Run Text="4. Copie steamLoginSecure et sessionid"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>

                            <!-- CONNECTED STATE -->
                            <StackPanel Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVis}}">
                                <Border Background="#0A1E0A" BorderBrush="{StaticResource GreenDarkBrush}"
                                        BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource GreenBrush}" FontSize="12" FontWeight="Bold"
                                                   Text="✓ Connecté"/>
                                        <TextBlock Text="{Binding UserName}" Foreground="{StaticResource TextBrush}"
                                                   FontSize="13" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Button Content="{Binding Loc.Disconnect}" Style="{StaticResource SteamButton}"
                                        Click="Logout_Click" Padding="12,6"/>
                            </StackPanel>

                            <Separator Margin="0,16"/>

                            <!-- IDLE OPTIONS -->
                            <TextBlock Text="{Binding Loc.Options}" Style="{StaticResource SectionHeader}"/>

                            <CheckBox Style="{StaticResource SteamCheckBox}"
                                      IsChecked="{Binding IsFastMode}"
                                      Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚀 " FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Loc.FastMode}" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                            <TextBlock Text="{Binding Loc.FastModeDesc}"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <Separator Margin="0,8"/>

                            <!-- STATS -->
                            <TextBlock Text="{Binding Loc.Stats}" Style="{StaticResource SectionHeader}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Column="0" Grid.Row="0">
                                    <TextBlock Text="{Binding Stats.TotalCardsDropped}" Style="{StaticResource StatValue}"/>
                                    <TextBlock Text="Cartes farmées" Style="{StaticResource StatLabel}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="0">
                                    <TextBlock Text="{Binding Stats.TotalGamesIdled}" Style="{StaticResource StatValue}"/>
                                    <TextBlock Text="Jeux terminés" Style="{StaticResource StatLabel}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2">
                                    <TextBlock Text="{Binding Stats.TotalIdleTimeText}" Style="{StaticResource StatValue}" FontSize="14"/>
                                    <TextBlock Text="Temps de session" Style="{StaticResource StatLabel}"/>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ─── RIGHT CONTENT ─────────────────────────────── -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Top bar -->
                        <RowDefinition Height="Auto"/>  <!-- Current idle card -->
                        <RowDefinition Height="*"/>     <!-- Badge list -->
                    </Grid.RowDefinitions>

                    <!-- TOP CONTROLS BAR -->
                    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Summary counts -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                    <TextBlock Text="🎮 " FontSize="16"/>
                                    <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="13">
                                        <Run Text="{Binding TotalGames}"/> <Run Text=" jeu(x)"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                    <TextBlock Text="🃏 " FontSize="16"/>
                                    <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="13">
                                        <Run Text="{Binding TotalCards}"/> <Run Text=" carte(s)"/>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="{Binding TimeUntilCheckText}"
                                           Foreground="{StaticResource AccentBrush}" FontSize="12"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsIdling, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="{Binding Loc.Refresh}" Style="{StaticResource SteamButton}"
                                        Click="Refresh_Click" Margin="0,0,8,0"
                                        IsEnabled="{Binding IsNotIdling}"/>
                                <Button Content="{Binding Loc.Start}" Style="{StaticResource SteamButtonGreen}"
                                        Click="Start_Click" Margin="0,0,8,0"
                                        Visibility="{Binding IsNotIdling, Converter={StaticResource BoolToVis}}"
                                        IsEnabled="{Binding IsAuthenticated}"/>
                                <Button Content="{Binding Loc.Stop}" Style="{StaticResource SteamButtonRed}"
                                        Click="Stop_Click"
                                        Visibility="{Binding IsIdling, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- CURRENT IDLE CARD -->
                    <Border Grid.Row="1"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12"
                            Visibility="{Binding IsIdling, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Game image -->
                            <Border Grid.Column="0" CornerRadius="4" ClipToBounds="True"
                                    Background="#0D1923" Width="75" Height="45">
                                <Image Source="{Binding CurrentBadge.ImageUrl}"
                                       Stretch="UniformToFill"/>
                            </Border>

                            <!-- Game info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                <TextBlock Text="{Binding Loc.Idling}"
                                           Foreground="{StaticResource GreenBrush}"
                                           FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CurrentBadge.Name}"
                                           Foreground="{StaticResource TextBrightBrush}"
                                           FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CurrentBadge.RemainingCardsText}"
                                           Foreground="{StaticResource TextDimBrush}" FontSize="12"/>
                            </StackPanel>

                            <!-- Animated idle indicator -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="⟳" Foreground="{StaticResource AccentBrush}"
                                           FontSize="24" VerticalAlignment="Center">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="SpinRotate" CenterX="12" CenterY="12"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="SpinRotate"
                                                                     Storyboard.TargetProperty="Angle"
                                                                     From="0" To="360" Duration="0:0:2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- BADGE LIST -->
                    <Grid Grid.Row="2">
                        <!-- Loading overlay -->
                        <Border Background="#AA1B2838" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                Panel.ZIndex="10">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="⟳" FontSize="48" Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="LoadingRotate" CenterX="24" CenterY="24"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="LoadingRotate"
                                                                     Storyboard.TargetProperty="Angle"
                                                                     From="0" To="360" Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                                <TextBlock Text="Chargement..." Foreground="{StaticResource TextBrush}"
                                           FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Empty state -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVis}}">
                            <TextBlock Text="🃏" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="{Binding Loc.ConnectToSee}"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="14"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Game list header -->
                        <Border Padding="16,8" Background="#0D1520"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                VerticalAlignment="Top" Height="36"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Loc.ImageCol}" Foreground="{StaticResource TextDimBrush}" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{Binding Loc.GameCol}" Foreground="{StaticResource TextDimBrush}" FontSize="10"/>
                                <TextBlock Grid.Column="2" Text="{Binding Loc.CardsCol}" Foreground="{StaticResource TextDimBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding Loc.HoursCol}" Foreground="{StaticResource TextDimBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{Binding Loc.PrioCol}" Foreground="{StaticResource TextDimBrush}" FontSize="10" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Badge list scrollable -->
                        <ScrollViewer Margin="0,36,0,0" VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding Badges}" Padding="0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="8,2" CornerRadius="4" Padding="8,6"
                                                Background="{StaticResource CardBrush}"
                                                BorderThickness="1">
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{StaticResource SteamBorder}" Opacity="0.4"/>
                                            </Border.BorderBrush>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="50"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Game image -->
                                                <Border Grid.Column="0" CornerRadius="3" ClipToBounds="True"
                                                        Background="#0D1923" Width="54" Height="32"
                                                        ToolTip="{Binding Name}">
                                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                                </Border>

                                                <!-- Name -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding HoursPlayedText}"
                                                               Foreground="{StaticResource TextDimBrush}"
                                                               FontSize="11"/>
                                                </StackPanel>

                                                <!-- Cards remaining -->
                                                <Border Grid.Column="2" HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Background="#0D1E2E" CornerRadius="3"
                                                        Padding="8,3">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🃏 " FontSize="12"/>
                                                        <TextBlock Text="{Binding RemainingCards}"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontWeight="Bold" FontSize="13"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Hours -->
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding HoursPlayed, StringFormat='{}{0:F1}h'}"
                                                           Foreground="{StaticResource TextDimBrush}"
                                                           FontSize="13"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>

                                                <!-- Priority button -->
                                                <Button Grid.Column="4"
                                                        Content="⬆"
                                                        ToolTip="Passer en priorité"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Width="30" Height="26"
                                                        Padding="0"
                                                        FontSize="14"
                                                        Style="{StaticResource SteamButton}"
                                                        Tag="{Binding}"
                                                        Click="PriorityButton_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!--  STATUS BAR                                              -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Background="#0D1520"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status dot + text -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource TextDimBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsIdling}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource GreenBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource OrangeBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource TextBrush}" FontSize="12"/>
                    </StackPanel>

                    <!-- Status detail -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusDetail}"
                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <!-- Steam status -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Steam" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,4,0"/>
                        <Ellipse Width="6" Height="6" x:Name="SteamStatusDot" Fill="{StaticResource GreenBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
