<Window x:Class="SteamCardFarmer.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paramètres" Width="380" Height="400"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Cursor="SizeAll">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0D1B2A" Offset="0"/>
                        <GradientStop Color="#1B2838" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0">
                    <TextBlock Text="⚙  PARAMÈTRES" Foreground="{StaticResource AccentBrush}"
                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="✕" Style="{StaticResource SteamButtonRed}"
                            HorizontalAlignment="Right" Padding="8,2" FontSize="13"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20">

                    <!-- Langue -->
                    <TextBlock Text="LANGUE / LANGUAGE" Style="{StaticResource SectionHeader}"/>
                    <ListBox x:Name="LangList" Background="Transparent" BorderThickness="0"
                             SelectionChanged="LangList_SelectionChanged" Margin="0,0,0,16">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{StaticResource CardBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1" CornerRadius="4" Padding="12,6">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueBrush}"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Separator Margin="0,4,0,16"/>

                    <!-- Son -->
                    <TextBlock Text="🔊 SON DE NOTIFICATION" Style="{StaticResource SectionHeader}"/>

                    <CheckBox x:Name="SoundEnabledCheck" Foreground="{StaticResource TextBrush}"
                              FontSize="13" Margin="0,0,0,10"
                              Checked="Sound_Changed" Unchecked="Sound_Changed">
                        <TextBlock Text="Activer le son" Foreground="{StaticResource TextBrush}"/>
                    </CheckBox>

                    <!-- Volume -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="35"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔊" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider Grid.Column="1" x:Name="VolumeSlider"
                                Minimum="0" Maximum="100" Value="100"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="Volume_Changed"
                                Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Grid.Column="2" x:Name="VolumeLabel"
                                   Text="100%" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="12" VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <ListBox x:Name="SoundList" Background="Transparent" BorderThickness="0"
                             SelectionChanged="SoundList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,3"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{StaticResource CardBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1" CornerRadius="4" Padding="12,8">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueBrush}"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
